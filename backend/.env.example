# FILE: backend/.env.example
# Copy this file to .env and fill in the values

# ─── Server ───────────────────────────────────
NODE_ENV=development
PORT=5000
API_VERSION=v1

# ─── Database ─────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/secure_vault?schema=public

# ─── Redis ────────────────────────────────────
REDIS_URL=redis://localhost:6379
# For Upstash Redis (production):
# REDIS_URL=rediss://:password@your-upstash-endpoint:6380

# ─── JWT ──────────────────────────────────────
JWT_SECRET=0556a1f4293969700fd5f84fb7894dc76fa7a2e8ed44b9af45b891e1b6d07bd5
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=1da6eb35d033e38ad0bb43c91d67b9bab40b06f4a95edb409ea657778862200a
JWT_REFRESH_EXPIRES_IN=7d

# ─── AWS S3 ───────────────────────────────────
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-s3-bucket-name
AWS_S3_SIGNED_URL_EXPIRES=3600

# ─── Rate Limiting ────────────────────────────
RATE_LIMIT_WINDOW_MS=1000
RATE_LIMIT_MAX_REQUESTS=2

# ─── Storage ──────────────────────────────────
MAX_FILE_SIZE_MB=50
DEFAULT_STORAGE_QUOTA_MB=10

# ─── CORS ─────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ─── Logging ──────────────────────────────────
LOG_LEVEL=debug
